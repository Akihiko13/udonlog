# ===========================================================================
# うどログ サーバー設定（Xサーバー / Apache）
# ---------------------------------------------------------------------------
# HTML / JS / CSS はキャッシュさせず、常に最新を読み込ませる。
# → ファイルを更新したら、そのファイルをアップするだけで即反映される
#   （バージョン番号 ?v= を毎回上げて全HTMLを上げ直す必要がなくなる）。
# 画像（favicon等）は変更が少ないのでキャッシュを許可（表示が速い）。
# ===========================================================================
# 存在しないページはブランド調の404ページを表示（404ステータスは維持）
ErrorDocument 404 /404.html

<IfModule mod_headers.c>
  <FilesMatch "\.(html|js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # 画像・フォントは長期キャッシュ（差し替える時はファイル名か ?v= を変える）
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# 店舗詳細のきれいなURL： /shops/＜slug＞ → shop-detail.html?slug=＜slug＞
# （ブラウザのURLは /shops/yamagoeudon のまま。内部で詳細ページを表示）
<IfModule mod_rewrite.c>
  RewriteEngine On

  # index.html へのアクセスは / に統一（重複URL・SEO評価の分散を防ぐ）
  # ※ THE_REQUEST で実リクエストを見るのでリダイレクトループにはならない
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  # 店舗詳細のきれいなURL： /shops/＜slug＞ → shop-detail.html?slug=＜slug＞
  # （ブラウザのURLは /shops/yamagoeudon のまま。内部で詳細ページを表示）
  RewriteRule ^shops/([A-Za-z0-9_-]+)/?$ shop-detail.html?slug=$1 [L,QSA]

  # 会員プロフィールのきれいなURL： /＜username＞ → user.html?u=＜username＞
  # （ブラウザのURLは /kagawan のまま。内部でプロフィールページを表示）
  # 実在するファイル・ディレクトリ（.html / api / uploads / images など）は除外し、
  # そのまま表示する。名前空間の衝突を避けるため、このルールは必ず最後に置く。
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^([A-Za-z0-9_]{3,20})/?$ user.html?u=$1 [L,QSA]
</IfModule>
