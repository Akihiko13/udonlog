# ===========================================================================
# うどログ サーバー設定（Xサーバー / Apache）
# ---------------------------------------------------------------------------
# HTML / JS / CSS はキャッシュさせず、常に最新を読み込ませる。
# → ファイルを更新したら、そのファイルをアップするだけで即反映される
#   （バージョン番号 ?v= を毎回上げて全HTMLを上げ直す必要がなくなる）。
# 画像（favicon等）は変更が少ないのでキャッシュを許可（表示が速い）。
# ===========================================================================
<IfModule mod_headers.c>
  <FilesMatch "\.(html|js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# 店舗詳細のきれいなURL： /shops/＜slug＞ → shop-detail.html?slug=＜slug＞
# （ブラウザのURLは /shops/yamagoeudon のまま。内部で詳細ページを表示）
<IfModule mod_rewrite.c>
  RewriteEngine On

  # index.html へのアクセスは / に統一（重複URL・SEO評価の分散を防ぐ）
  # ※ THE_REQUEST で実リクエストを見るのでリダイレクトループにはならない
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  # 店舗詳細のきれいなURL： /shops/＜slug＞ → shop-detail.html?slug=＜slug＞
  # （ブラウザのURLは /shops/yamagoeudon のまま。内部で詳細ページを表示）
  RewriteRule ^shops/([A-Za-z0-9_-]+)/?$ shop-detail.html?slug=$1 [L,QSA]
</IfModule>
